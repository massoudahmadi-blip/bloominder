# Copy to api/.env and adjust. Never commit the real .env.
PORT=3001

# Connect to the PostGIS database from SETUP.md.
# Local dev against the VPS DB tunnel, or the same box:
DATABASE_URL=postgres://bloominder:change-me@localhost:5432/bloominder

# Comma-separated allowed origins for CORS (the frontend). "*" for dev only.
CORS_ORIGIN=*
