# Copy this file to ".env" on the VPS and fill in the values.
#   cp .env.example .env  &&  nano .env
# Never commit the real .env to git.

# --- Database ---
POSTGRES_DB=bloominder
POSTGRES_USER=bloominder
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# --- Production (only needed for `docker compose --profile prod up`) ---
# Your domain WITHOUT www or protocol. Caddy serves DOMAIN, www.DOMAIN, and api.DOMAIN.
DOMAIN=bloominder.com
# Email for Let's Encrypt expiry notices.
ACME_EMAIL=massoud.ahmadi@gmail.com
